# Supabase — find these in your project's API settings (Project Settings → API)
# URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable (client-safe) key — format: sb_publishable_...
# This is safe to expose to the browser; Row-Level Security enforces access.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
